{
  "name": "dawaah-ui-smoke",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "features:generate": "node scripts/generate-feature-modules.js",
    "runtime:split": "node scripts/split-runtime-modules.js",
    "runtime:assemble": "node scripts/assemble-runtime-bundles.js",
    "build": "npm run runtime:assemble && powershell -ExecutionPolicy Bypass -File scripts/build-firebase-public.ps1",
    "serve": "http-server . -p 8000 -c-1",
    "serve:public": "http-server firebase-public -p 8000 -c-1",
    "test:ui": "playwright test tests/ui-smoke.spec.js",
    "test:local": "start-server-and-test \"npm run serve\" http://127.0.0.1:8000/index.html \"playwright test tests/ui-smoke.spec.js\"",
    "test:rules": "firebase emulators:exec --only firestore \"node --test tests/firestore-rules.test.js\"",
    "test:rules:existing": "cross-env FIRESTORE_EMULATOR_HOST=127.0.0.1:9195 node --test tests/firestore-rules.test.js",
    "test:live": "playwright test tests/live-feature-audit.spec.js --workers=1",
    "backup:firestore": "node scripts/export-firestore-backup.js",
    "cleanup:live-audit": "node scripts/cleanup-live-audit-users.js",
    "claims:set": "node scripts/set-custom-claims.js",
    "admin:server-action": "node scripts/server-admin-action.js"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.52.0",
    "cross-env": "^7.0.3",
    "firebase": "^10.14.1",
    "firebase-admin": "^13.6.0",
    "firebase-tools": "^15.18.0",
    "http-server": "^14.1.1",
    "start-server-and-test": "^2.0.12"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.4.0",
    "bootstrap": "^5.3.0",
    "chart.js": "^3.9.1"
  }
}
