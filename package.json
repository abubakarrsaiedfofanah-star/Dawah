{
  "name": "dawah-ui-smoke",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "features:generate": "node scripts/generate-feature-modules.js",
    "runtime:split": "node scripts/split-runtime-modules.js",
    "runtime:assemble": "node scripts/assemble-runtime-bundles.js",
    "config:supabase": "node scripts/generate-supabase-config.js",
    "build": "npm run config:supabase && npm run runtime:assemble",
    "serve": "http-server . -p 8000 -c-1",
    "test:ui": "playwright test tests/ui-smoke.spec.js",
    "test:local": "start-server-and-test \"npm run serve\" http://127.0.0.1:8000/index.html \"playwright test tests/ui-smoke.spec.js\""
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "cross-env": "^7.0.3",
    "http-server": "^14.1.1",
    "start-server-and-test": "^2.0.12"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.4.0",
    "bootstrap": "^5.3.0",
    "chart.js": "^3.9.1"
  }
}
